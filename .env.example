# Redis
REDIS_URL=redis://redis:6379/0

# Gemini (cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local)
# Use host.docker.internal when running inside Docker on Windows/macOS
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Default provider: ollama (local dev) | gemini (production)
DEFAULT_LLM_PROVIDER=ollama

# Search (Phase 11) — DuckDuckGo default; set Tavily key to prefer Tavily
TAVILY_API_KEY=
SEARCH_MAX_URLS=3
SEARCH_FETCH_TIMEOUT_SECONDS=15

# Multi-cloud ops control plane
OPS_LOCAL_BASE_URL=http://127.0.0.1:8000
OPS_HETZNER_REGION=fsn1
# Optional second/third stacks (full Tess compose on each cloud)
OPS_AWS_BASE_URL=http://18.227.172.81
OPS_AWS_REGION=us-east-2
OPS_AWS_CREDENTIALS_REF=AWS_ROLE_ARN
OPS_GCP_BASE_URL=
OPS_GCP_REGION=us-central1
OPS_GCP_CREDENTIALS_REF=GCP_SERVICE_ACCOUNT_JSON
OPS_PREFERRED_PROVIDER_ID=
# REQUIRED for mutating /ops endpoints (force switch drops sessions). Unset = 503.
OPS_ADMIN_TOKEN=
OPS_PROBE_INTERVAL_SECONDS=30
OPS_FAILOVER_FAILURE_THRESHOLD=3
OPS_FAILOVER_RECOVERY_THRESHOLD=2
OPS_LATENCY_THRESHOLD_MS=5000
OPS_PROBE_ENABLED=true
OPS_PERSIST_ENABLED=true

# AWS standby scripts (scripts/aws_standby.py) — local operator machine only
# Run from your laptop; export these or put them in .env (script does not read .env.prod).
AWS_STANDBY_INSTANCE_ID=i-0360ab28632a3c4a0
AWS_STANDBY_REGION=us-east-2
# Exact name from AWS Console → Billing → Budgets (required for `cycle`; optional for `wake`)
AWS_BUDGET_NAME=
AWS_BUDGET_ALERT_THRESHOLD=0.80
AWS_STANDBY_HEALTH_TIMEOUT_S=180
# Hetzner control plane — where /ops/* runs and smoke test probes failover (NOT the AWS URL)
OPS_SMOKE_BASE_URL=https://5.78.186.223
# OPS_ADMIN_TOKEN documented above; OPS_SMOKE_PRIMARY=prov_hetzner_local OPS_SMOKE_STANDBY=prov_aws
