# Redis
REDIS_URL=redis://redis:6379/0

# Gemini (cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local)
# Use host.docker.internal when running inside Docker on Windows/macOS
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Default provider: ollama (local dev) | gemini (production)
DEFAULT_LLM_PROVIDER=ollama

# Search (Phase 11) — DuckDuckGo default; set Tavily key to prefer Tavily
TAVILY_API_KEY=
SEARCH_MAX_URLS=3
SEARCH_FETCH_TIMEOUT_SECONDS=15

# Multi-cloud ops control plane
OPS_LOCAL_BASE_URL=http://127.0.0.1:8000
# Public chat WS advertised by ops-ui (Hetzner CP). Avoid leaving loopback in demos.
# OPS_PUBLIC_WS_BASE_URL=ws://5.78.186.223
# or wss://your.domain
OPS_PUBLIC_WS_BASE_URL=
OPS_HETZNER_REGION=fsn1
# Optional second/third stacks (full Tess compose on each cloud)
OPS_AWS_BASE_URL=http://18.227.172.81
OPS_AWS_REGION=us-east-2
OPS_AWS_CREDENTIALS_REF=AWS_ROLE_ARN
OPS_GCP_BASE_URL=http://34.46.222.191
OPS_GCP_REGION=us-central1
OPS_GCP_CREDENTIALS_REF=GCP_SERVICE_ACCOUNT_JSON
OPS_PREFERRED_PROVIDER_ID=
# Admin auth for /ops (mutations + sensitive GETs). Fail-closed if both empty.
# Preferred: JSON map of operator_id -> token (audit which operator acted).
# OPS_ADMIN_TOKENS={"jesse":"replace-me","alice":"replace-me"}
OPS_ADMIN_TOKENS=
# Legacy single shared secret (maps to operator id "legacy"); scripts still use this.
OPS_ADMIN_TOKEN=
OPS_PROBE_INTERVAL_SECONDS=30
OPS_FAILOVER_FAILURE_THRESHOLD=3
OPS_FAILOVER_RECOVERY_THRESHOLD=2
OPS_LATENCY_THRESHOLD_MS=5000
OPS_PROBE_ENABLED=true
OPS_PERSIST_ENABLED=true

# AWS standby scripts (scripts/aws_standby.py) — laptop OR Celery worker on CP
# Ops UI Wake / auto_wake enqueue Celery → these scripts; creds must exist where
# the worker runs (Hetzner) for server-side wake/sleep. Laptop-only is fine if
# you only use `python scripts/aws_standby.py` locally.
# Run from your laptop; export these or put them in .env (script does not read .env.prod).
AWS_STANDBY_INSTANCE_ID=i-0360ab28632a3c4a0
AWS_STANDBY_REGION=us-east-2
# Exact name from AWS Console → Billing → Budgets (required for `cycle`; optional for `wake`)
AWS_BUDGET_NAME=
AWS_BUDGET_ALERT_THRESHOLD=0.80
AWS_STANDBY_HEALTH_TIMEOUT_S=180
# drift-check: set to 1 during an intentional wake so a daily cron does not alarm
AWS_STANDBY_ALLOW_RUNNING=
# Hetzner control plane — where /ops/* runs and smoke test probes failover (NOT the AWS URL)
# Use http:// for IP-only Hetzner deploys (no TLS on :443)
OPS_SMOKE_BASE_URL=http://5.78.186.223
# OPS_ADMIN_TOKEN documented above; OPS_SMOKE_PRIMARY=prov_hetzner_local OPS_SMOKE_STANDBY=prov_aws|prov_gcp

# GCP standby scripts (scripts/gcp_standby.py) — local operator machine only
# Auth: GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json  OR  gcloud ADC
GCP_STANDBY_PROJECT_ID=tess-503119
GCP_STANDBY_ZONE=us-central1-a
GCP_STANDBY_INSTANCE_NAME=tess-gcp-primary
GCP_STANDBY_HEALTH_TIMEOUT_S=180
# drift-check: set to 1 during an intentional wake so a daily cron does not alarm
GCP_STANDBY_ALLOW_RUNNING=
# Optional: set OPS_SMOKE_STANDBY=prov_gcp when exercising GCP failover smoke
