# Redis
REDIS_URL=redis://redis:6379/0

# Gemini (cloud)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Ollama (local)
# Use host.docker.internal when running inside Docker on Windows/macOS
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Default provider: ollama (local dev) | gemini (production)
DEFAULT_LLM_PROVIDER=ollama
