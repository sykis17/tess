# Required — use your domain, or server IP for testing without TLS (e.g. 5.78.186.223)
DOMAIN=5.78.186.223
REDIS_URL=redis://redis:6379/0

# Frontend build (used by deploy script / frontend Dockerfile)
VITE_WS_BASE_URL=ws://5.78.186.223

# --- LLM provider: ollama (initial testing) or gemini (production) ---
DEFAULT_LLM_PROVIDER=ollama
# Use the internal Docker service name (do not use localhost or host.docker.internal)
OLLAMA_BASE_URL=http://ollama:11434
# Use llama3.2:1b on 4 GB servers (CPX11). Use llama3.2 on 8 GB+ servers.
OLLAMA_MODEL=llama3.2:1b
# Multi-POV chains issue many sequential LLM calls; allow 5 minutes per call on CPX11.
OLLAMA_REQUEST_TIMEOUT_SECONDS=300
# Throttle token-stream Redis publishes (milliseconds) on CPX11
STREAM_THROTTLE_MS=75
PROGRESS_HEARTBEAT_SECONDS=10
PIPELINE_SOFT_TIME_LIMIT_SECONDS=900

# Phase 21 — skip presenter follow-up LLM on CPX11 (static/topic-fallback chips only)
# Also auto-enabled when OLLAMA_MODEL contains :1b
SKIP_LLM_FOLLOW_UPS=false

# Gemini (enable when billing/quota is ready)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Search (Phase 11) — DuckDuckGo default; set Tavily key to prefer Tavily
TAVILY_API_KEY=
SEARCH_MAX_URLS=3
SEARCH_FETCH_TIMEOUT_SECONDS=15
