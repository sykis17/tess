# Required — use your domain, or server IP for testing without TLS (e.g. 5.78.186.223)
DOMAIN=tess.example.com
GEMINI_API_KEY=
REDIS_URL=redis://redis:6379/0
DEFAULT_LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

# Frontend build (used by deploy script / frontend Dockerfile)
VITE_WS_BASE_URL=wss://tess.example.com

# Optional — only if running Ollama on the same host
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL=llama3.2
